# AEM Connection
APP_HOST_URI=https://author-p18253-e46622.adobeaemcloud.com
APP_PUBLISH_URI=https://publish-p18253-e46622.adobeaemcloud.com
APP_ENDPOINT=securbank
APP_GRAPHQL_ENDPOINT=/content/graphql/global/endpoint.json

# Authentication: basic | service-token | none
APP_AUTH_METHOD=basic
APP_BASIC_AUTH_USER=securbank
APP_BASIC_AUTH_PASS=your-password
APP_SERVICE_TOKEN=

# AEM Embed (optional - for header/footer from AEM Edge Delivery)
# URLs to AEM.live / Edge Delivery pages. When set, replaces default header/footer.
# APP_AEM_EMBED_HEADER_URL=https://main--site--org.aem.page/
# APP_AEM_EMBED_FOOTER_URL=https://main--site--org.aem.page/

# Okta (for Sign In)
APP_OKTA_ISSUER=https://your-tenant.okta.com/oauth2/default
APP_OKTA_CLIENT_ID=your-client-id
APP_OKTA_REDIRECT_URI=https://your-app.vercel.app/login/callback
APP_OKTA_SCOPES=openid profile email

# Server
PORT=3001
